generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// ENUMS
//

enum UserRole {
  SUPERADMIN
  ADMIN
  CLIENT
  PERFORMER
}

enum OrderStatus {
  CREATED
  PENDING
  PAID
  IN_PROGRESS
  SHIPPED
  DONE
  CANCELED
}

enum ProductType {
  SIMPLE
  CONFIGURATOR
  REQUEST_QUOTE
}

enum PriceType {
  FIXED
  QUOTE
}

enum FileCategory {
  AVATAR
  PRODUCT_IMAGE
  CATEGORY_IMAGE
  ORDER_DOCUMENT
  QUOTE_ATTACHMENT
  BRANDING
}

//
// USERS
//

model User {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String

  avatarId String? @unique // FK to File (one-to-one)
  avatar   File?   @relation("UserAvatar", fields: [avatarId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  sessions Session[]
  orders   Order[]
  quotes   QuoteRequest[]
  logs     ActivityLog[]
}

model Session {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  token     String   @unique
  expiresAt DateTime

  createdAt DateTime @default(now())
}

//
// CATALOG
//

model Category {
  id String @id @default(cuid())

  name        String
  slug        String  @unique
  title       String?
  description String?

  imageId String? @unique // FK to File (category image)
  image   File?   @relation("CategoryImage", fields: [imageId], references: [id], onDelete: SetNull)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id String @id @default(cuid())

  title String
  slug  String @unique

  description String?

  type ProductType @default(SIMPLE)

  priceType PriceType @default(FIXED)
  price     Float?

  characteristics Json? // массив { key, value }

  article String?

  isActive Boolean @default(true)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  images File[] // вместо ProductImage[]

  attributes Json? // гибкие параметры (котлы, конфигураторы)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems    OrderItem[]
  quoteRequests QuoteRequest[]
}

// ProductImage удалён — заменён на File с category: PRODUCT_IMAGE

//
// ORDERS (B2B/B2C)
//

model Order {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  status OrderStatus @default(CREATED)

  total Int @default(0)

  items     OrderItem[]
  documents File[] // документы заказа

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int @default(1)
  price    Int
}

model Visit {
  id        String  @id @default(cuid())
  path      String
  ip        String?
  userAgent String?
  referrer  String?

  createdAt DateTime @default(now())
}

model Event {
  id String @id @default(cuid())

  type String // "CLICK" | "QUOTE" | "ORDER" | "VIEW"
  path String?

  productId String?
  userId    String?

  metadata Json?

  createdAt DateTime @default(now())
}

//
// QUOTES / КП (очень важно для котлов и B2B)
//

model QuoteRequest {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  message String?

  status String @default("NEW")

  payload Json? // конфигуратор котла

  attachments File[] // вложения к заявке

  createdAt DateTime @default(now())
}

//
// LOGS / ANALYTICS
//

model ActivityLog {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  action String
  meta   Json?

  createdAt DateTime @default(now())
}

//
// FILES / S3
//

model File {
  id        String       @id @default(cuid())
  bucketKey String // ключ в S3 (например "avatars/user123.jpg")
  url       String // публичный URL
  mimeType  String // image/png, application/pdf
  size      Int // размер в байтах
  category  FileCategory
  fileName  String // оригинальное имя файла

  // Полиморфные связи (optional)
  // UserAvatar — обратная связь, FK на стороне User (avatarId)
  user User? @relation("UserAvatar")

  // CategoryImage — обратная связь, FK на стороне Category (imageId)
  categoryImage Category? @relation("CategoryImage")

  productId String? // для изображений товаров
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  orderId String? // для документов заказа
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  quoteId String? // для вложений заявки
  quote   QuoteRequest? @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}
