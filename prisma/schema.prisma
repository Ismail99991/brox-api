generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// ENUMS
//

enum CrmRole {
  SUPERADMIN
  ADMIN
  MANAGER
  LOGIST
}

enum OrderStatus {
  CREATED
  PENDING
  PAID
  IN_PROGRESS
  SHIPPED
  DONE
  CANCELED
}

enum ProductType {
  SIMPLE
  CONFIGURATOR
  REQUEST_QUOTE
}

enum PriceType {
  FIXED
  QUOTE
}

enum FileCategory {
  AVATAR
  PRODUCT_IMAGE
  CATEGORY_IMAGE
  ORDER_DOCUMENT
  QUOTE_ATTACHMENT
  BRANDING
}

//
// CRM — СОТРУДНИКИ КОМПАНИИ
// Доступ: только по приглашению администратора
//

model CrmUser {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
  name         String?
  role         CrmRole @default(MANAGER)

  avatarId String? @unique
  avatar   File?   @relation("CrmUserAvatar", fields: [avatarId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions   CrmSession[]
  logs       ActivityLog[]
}

model CrmSession {
  id String @id @default(cuid())

  crmUserId String
  crmUser   CrmUser @relation(fields: [crmUserId], references: [id], onDelete: Cascade)

  token     String   @unique
  expiresAt DateTime

  createdAt DateTime @default(now())
}

//
// MARKET — КЛИЕНТЫ (B2B-покупатели)
// Доступ: самостоятельная регистрация
//

model MarketUser {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String

  name  String?
  phone String?

  avatarId String? @unique
  avatar   File?   @relation("MarketUserAvatar", fields: [avatarId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders         Order[]
  quotes         QuoteRequest[]
  favorites      Favorite[]
  cartItems      CartItem[]
  passwordTokens PasswordResetToken[]
}

//
// CATALOG
//

model Category {
  id String @id @default(cuid())

  name        String
  slug        String  @unique
  title       String?
  description String?

  imageId String? @unique
  image   File?   @relation("CategoryImage", fields: [imageId], references: [id], onDelete: SetNull)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id String @id @default(cuid())

  title String
  slug  String @unique

  description String?

  type ProductType @default(SIMPLE)

  priceType PriceType @default(FIXED)
  price     Float?

  characteristics Json? // [{ key, value }]

  article String?

  isActive Boolean @default(true)

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  images File[]

  attributes Json? // гибкие параметры

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems    OrderItem[]
  quoteRequests QuoteRequest[]
  favorites     Favorite[]
  cartItems     CartItem[]
}

//
// ORDERS (B2B — привязаны к MarketUser)
//

model Order {
  id String @id @default(cuid())

  marketUserId String
  marketUser   MarketUser @relation(fields: [marketUserId], references: [id])

  status OrderStatus @default(CREATED)

  total Int @default(0)

  items     OrderItem[]
  documents File[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderItem {
  id String @id @default(cuid())

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity Int @default(1)
  price    Int
}

//
// VISITS & EVENTS (аналитика)
//

model Visit {
  id        String  @id @default(cuid())
  path      String
  ip        String?
  userAgent String?
  referrer  String?

  createdAt DateTime @default(now())
}

model Event {
  id String @id @default(cuid())

  type String // "CLICK" | "QUOTE" | "ORDER" | "VIEW"
  path String?

  productId String?
  marketUserId String?

  metadata Json?

  createdAt DateTime @default(now())
}

//
// QUOTES / КП (B2B — привязаны к MarketUser)
//

model QuoteRequest {
  id String @id @default(cuid())

  marketUserId String
  marketUser   MarketUser @relation(fields: [marketUserId], references: [id])

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  message String?

  status String @default("NEW")

  payload Json? // конфигуратор котла

  attachments File[]

  createdAt DateTime @default(now())
}

//
// FAVORITES (маркет)
//

model Favorite {
  id        String   @id @default(cuid())
  marketUserId    String
  marketUser      MarketUser @relation(fields: [marketUserId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([marketUserId, productId])
}

//
// CART (маркет)
//

model CartItem {
  id        String   @id @default(cuid())
  marketUserId    String
  marketUser      MarketUser @relation(fields: [marketUserId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([marketUserId, productId])
}

//
// PASSWORD RESET (маркет)
//

model PasswordResetToken {
  id        String   @id @default(cuid())
  marketUserId    String
  marketUser      MarketUser @relation(fields: [marketUserId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)

  createdAt DateTime @default(now())
}

//
// CALLBACK (публичная форма)
//

model CallbackRequest {
  id        String   @id @default(cuid())
  name      String
  phone     String
  comment   String?
  status    String   @default("NEW")

  createdAt DateTime @default(now())
}

//
// LOGS (CRM)
//

model ActivityLog {
  id String @id @default(cuid())

  crmUserId String?
  crmUser   CrmUser? @relation(fields: [crmUserId], references: [id])

  action String
  meta   Json?

  createdAt DateTime @default(now())
}

//
// FILES / S3
//

model File {
  id        String       @id @default(cuid())
  bucketKey String
  url       String
  mimeType  String
  size      Int
  category  FileCategory
  fileName  String

  // CRM avatar
  crmAvatar CrmUser? @relation("CrmUserAvatar")

  // Market avatar
  marketAvatar MarketUser? @relation("MarketUserAvatar")

  // Category image
  categoryImage Category? @relation("CategoryImage")

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  quoteId String?
  quote   QuoteRequest? @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}
